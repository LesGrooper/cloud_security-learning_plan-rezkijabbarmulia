{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "dummy_files",
      "Effect": "Allow",
      "Action": [
        "ec2:dummy_files",
        "ec2:dummy_files",
        "cloudwatch:dummy_files",
        "cloudwatch:dummy_files"
      ],
      "Resource": "*",
      "Condition": {
        "IpAddress": {
          "aws:SourceIp": ["10.0.0.0/8", "192.168.1.0/24"]
        }
      }
    },
    {
      "Sid": "dummy_files",
      "Effect": "dummy_files",
      "Action": ["dummy_files:*", "dummy_files:*", "dummy_files:*"],
      "Resource": "*"
    }
  ]
}